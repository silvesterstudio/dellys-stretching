# Supabase — copy to .env.local and fill in from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used by admin actions and edge functions that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for OTP redirect links). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
